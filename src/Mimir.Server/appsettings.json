{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Mimir": "Host=postgres;Port=5432;Database=mimir;Username=mimir;Password=mimir"
  },
  "Mimir": {
    "Server": {
      "Port": 6464
    },
    "Models": {
      "Endpoint": "http://ollama:11434",
      "Distiller": "qwen3:8b",
      "Embedding": "qwen3-embedding:0.6b",
      "EmbeddingDimensions": 1024
    },
    "Capture": {
      "PayloadFieldCapBytes": 4096,
      "PayloadHeadBytes": 3072,
      "PayloadTailBytes": 1024
    },
    "Harvest": {
      "Root": "/harvest",
      "ScanInterval": "00:05:00",
      "CandidateCap": 2000
    },
    "Search": {
      "RrfK": 60,
      "PerLegTopN": 50
    },
    "Distillation": {
      "MergeMatchThreshold": 0.80,
      "ContestedDuration": "14.00:00:00",
      "SweepInterval": "06:00:00",
      "StaleRunningAfter": "01:00:00",
      "CrashSealIdleAfter": "1.00:00:00",
      "ChunkTokens": 12288
    },
    "Recall": {
      "BriefBudgetChars": 4000,
      "RecencyHalfLifeDays": 90,
      "RecencyFloor": 0.3,
      "SalienceBoost": 1.3
    }
  }
}
