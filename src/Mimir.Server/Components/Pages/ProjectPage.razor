@page "/projects/{ProjectId:guid}"
@page "/projects/{ProjectId:guid}/{Tab}"
@using Mimir.Server.Components.Episodes
@using Mimir.Server.Components.Wisdom
@using Mimir.Server.Ui
@inject EpisodeBrowser Browser

<PageTitle>@(_project?.DisplayName ?? "Project") · Mimir</PageTitle>

@if (_project is null)
{
    <h1>Unknown Project</h1>
    <p class="lede">Nothing lives at this id — the Project may have been deleted.</p>
}
else
{
    <h1>@_project.DisplayName</h1>

    @* Spec §8: the three tabs, in spec order. Injections stays a stub until the Recall tickets;
       Episodes remains the default landing. *@
    <nav class="tab-strip" aria-label="Project surfaces">
        <a class="tab @(ActiveTab == "wisdom" ? "active" : null)" href="@Href("wisdom")">Wisdom</a>
        <a class="tab @(ActiveTab == "episodes" ? "active" : null)" href="@Href("episodes")">Episodes</a>
        <a class="tab @(ActiveTab == "injections" ? "active" : null)" href="@Href("injections")">Injections</a>
    </nav>

    @switch (ActiveTab)
    {
        case "wisdom":
            <WisdomBrowserTab ProjectId="ProjectId" />
            break;

        case "injections":
            <p class="tab-stub">The Injection log arrives with the Recall tickets.</p>
            break;

        default:
            <EpisodeTimeline ProjectId="ProjectId" IsGlobal="_project.IsGlobal" />
            break;
    }
}

@code {
    [Parameter]
    public Guid ProjectId { get; set; }

    [Parameter]
    public string? Tab { get; set; }

    private ProjectListItem? _project;

    private string ActiveTab => Tab?.ToLowerInvariant() switch
    {
        "wisdom" => "wisdom",
        "injections" => "injections",
        _ => "episodes",
    };

    private string Href(string tab) => $"projects/{ProjectId}/{tab}";

    protected override async Task OnParametersSetAsync()
        => _project = await Browser.GetProjectAsync(ProjectId, CancellationToken.None);
}
