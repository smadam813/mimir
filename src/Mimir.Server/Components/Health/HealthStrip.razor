@using Mimir.Contracts.Health
@using Mimir.Server.Health
@using Mimir.Server.Storage
@implements IDisposable
@inject IHealthState HealthState

@* Spec §8: the four-tile health strip, pinned above every surface. *@
<section class="health-strip" aria-label="Health">
    <HealthTile Title="Ollama" State="_snapshot.Ollama.State" Summary="@_snapshot.Ollama.Summary">
        @foreach (var model in _snapshot.Ollama.Models)
        {
            <div class="detail-row">
                <span class="detail-name">@model.Name</span>
                <span class="detail-value">@DescribeModel(model)</span>
            </div>
        }
    </HealthTile>

    <HealthTile Title="Distillation" Placeholder="Arrives with the Distiller" />

    <HealthTile Title="Harvester" State="_snapshot.Harvester.State" Summary="@_snapshot.Harvester.Summary">
        @if (_snapshot.Harvester.LastScanAt is { } lastScan)
        {
            <div class="detail-row">
                <span class="detail-name">last scan</span>
                <span class="detail-value">@lastScan.LocalDateTime.ToString("HH:mm:ss")</span>
            </div>
        }
        @if (_snapshot.Harvester.Items is { } harvestedItems)
        {
            <div class="detail-row">
                <span class="detail-name">items</span>
                <span class="detail-value">@harvestedItems</span>
            </div>
        }
        @if (_snapshot.Harvester.Changed is { } harvestedChanged)
        {
            <div class="detail-row">
                <span class="detail-name">changed</span>
                <span class="detail-value">@harvestedChanged</span>
            </div>
        }
    </HealthTile>

    <HealthTile Title="Storage" State="_snapshot.Storage.State" Summary="@_snapshot.Storage.Summary">
        @foreach (var table in _snapshot.Storage.Tables)
        {
            <div class="detail-row">
                <span class="detail-name">@table.Table</span>
                <span class="detail-value">@DescribeTable(table)</span>
            </div>
        }
    </HealthTile>
</section>

@code {
    private HealthSnapshot _snapshot = HealthSnapshot.Pending;
    private IDisposable? _subscription;

    protected override void OnInitialized()
    {
        _snapshot = HealthState.Current;

        // Probes push from background threads; hop onto the circuit's dispatcher to re-render.
        // This is what makes the strip live without a page refresh (spec §8).
        _subscription = HealthState.Subscribe(snapshot => InvokeAsync(() =>
        {
            _snapshot = snapshot;
            StateHasChanged();
        }));
    }

    public void Dispose() => _subscription?.Dispose();

    // Emptiness is carried in words, never inferred from the byte figure — a 28 MB heap can hold
    // zero live rows. Only the two states we can prove get to say anything; everything else, an
    // added enum member included, falls through to admitting we do not know.
    private static string DescribeTable(TableFootprint table) => table.Occupancy switch
    {
        TableOccupancy.Populated => ByteSize.Format(table.TotalBytes),
        TableOccupancy.Empty => $"{ByteSize.Format(table.TotalBytes)} · empty",
        _ => $"{ByteSize.Format(table.TotalBytes)} · occupancy unknown",
    };

    private static string DescribeModel(ModelStatus model) => model.State switch
    {
        ModelProvisioningState.Pulling when model.PercentComplete is { } percent => $"pulling {percent}%",
        ModelProvisioningState.Pulling => "pulling",
        ModelProvisioningState.Ready => "ready",
        ModelProvisioningState.Failed => model.Error ?? "failed",
        _ => "pending",
    };
}
