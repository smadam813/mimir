@inherits LayoutComponentBase

@* Spec §8: the health strip is pinned on top of every surface. The project sidebar and the
   Wisdom / Episodes / Injections tabs arrive with the tickets that own those surfaces. *@
<header class="app-header">
    <a class="app-brand" href="/">Mimir</a>
    <HealthStrip />
</header>

<main class="app-body">
    @Body
</main>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
