# Copy to .env if you need to override anything. Every value here has a working default.

# Postgres password. Localhost is the trust boundary (spec §12), so the default is fine for a
# single-user machine — change it if your Docker daemon is exposed.
# POSTGRES_PASSWORD=mimir

# Where Claude Code keeps its auto-memory. Set on hosts that do not define USERPROFILE
# (i.e. anything that is not Windows); Compose mounts `<this>/.claude/projects` read-only.
# USERPROFILE=/home/you
